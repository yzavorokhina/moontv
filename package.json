{
  "name": "moon_tv",
  "version": "1.0.0",
  "description": "front_end_for_moon_tv_streaming_service",
  "keywords": [
    "streams",
    "tv"
  ],
  "license": "ISC",
  "author": "Yuliya Zavorokhina",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "clean": "rimraf dist",
    "clean:wp": "rimraf node_modules/.cache/webpack",
    "clean:all": "rimraf dist && rimraf node_modules && rimraf package-lock.json",
    "build": "npx webpack build --stats-error-details",
    "dev": "npx webpack --watch",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "server": "npx webpack serve",
    "run-stylelint": "npx stylelint \"**/*.css\""
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "jquery": "^3.7.1",
    "lodash": "^4.17.21",
    "react": "^19.2.3",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "babel-loader": "^10.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "gh-pages": "^6.3.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.4",
    "mini-css-extract-plugin": "^2.9.4",
    "react-compiler-webpack": "^1.0.0",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.6",
    "style-loader": "^4.0.0",
    "stylelint": "^17.8.0",
    "stylelint-config-standard": "^40.0.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  }
}
